# =========================
# CodePilot AI env example
# Copy this file to .env and fill your real secrets locally.
# Do NOT commit .env.
# =========================

# GitHub API
CODEPILOT_GITHUB_TOKEN=
CODEPILOT_GITHUB_COMMENT_ENABLED=false
CODEPILOT_GITHUB_COMMENT_MARKER=<!-- codepilot-ai-review:liche719/codeAireview -->
CODEPILOT_GITHUB_INLINE_COMMENT_ENABLED=false
CODEPILOT_GITHUB_INLINE_COMMENT_MAX_PER_TASK=10

# GitHub Webhook
CODEPILOT_GITHUB_WEBHOOK_ENABLED=false
CODEPILOT_GITHUB_WEBHOOK_SECRET=
CODEPILOT_GITHUB_WEBHOOK_SKIP_SIGNATURE_WHEN_SECRET_EMPTY=false

# LLM
CODEPILOT_LLM_API_KEY=
CODEPILOT_LLM_BASE_URL=https://api.openai.com/v1
CODEPILOT_LLM_MODEL=gpt-4o-mini

# Embedding
CODEPILOT_EMBEDDING_API_KEY=
CODEPILOT_EMBEDDING_BASE_URL=https://api.openai.com/v1
CODEPILOT_EMBEDDING_MODEL=text-embedding-3-small

# Review Limits
CODEPILOT_REVIEW_MAX_FILES_PER_TASK=30
CODEPILOT_REVIEW_MAX_PATCH_CHARS_PER_FILE=12000
CODEPILOT_REVIEW_MAX_TOTAL_PATCH_CHARS=80000

# PostgreSQL
CODEPILOT_DB_NAME=codepilot
CODEPILOT_DB_URL=jdbc:postgresql://localhost:5432/codepilot
CODEPILOT_DB_USERNAME=codepilot
CODEPILOT_DB_PASSWORD=codepilot123

# Redis
CODEPILOT_REDIS_HOST=localhost
CODEPILOT_REDIS_PORT=6379
CODEPILOT_REDIS_DATABASE=0
CODEPILOT_REDIS_TIMEOUT=3s

# RabbitMQ
CODEPILOT_RABBITMQ_HOST=localhost
CODEPILOT_RABBITMQ_PORT=5672
CODEPILOT_RABBITMQ_USERNAME=codepilot
CODEPILOT_RABBITMQ_PASSWORD=codepilot123
CODEPILOT_RABBITMQ_VIRTUAL_HOST=/
