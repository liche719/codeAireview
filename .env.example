# =========================
# CodePilot AI env example
# Copy this file to .env and fill your real secrets locally.
# Do NOT commit .env.
# =========================

# Internal REST API auth
CODEPILOT_API_AUTH_ENABLED=true
CODEPILOT_API_AUTH_API_KEY=change-me-local-dev-key
CODEPILOT_API_AUTH_HEADER_NAME=X-CodePilot-Api-Key
CODEPILOT_API_AUTH_PROTECTED_PATH_PATTERNS=/api/**
CODEPILOT_API_AUTH_EXCLUDE_PATH_PATTERNS=/api/github/webhook,/api/github/webhook/**

# Internal REST API fixed-window rate limit
CODEPILOT_API_RATE_LIMIT_ENABLED=true
CODEPILOT_API_RATE_LIMIT_MAX_REQUESTS_PER_WINDOW=60
CODEPILOT_API_RATE_LIMIT_WINDOW=60s
CODEPILOT_API_RATE_LIMIT_PROTECTED_PATH_PATTERNS=/api/**
CODEPILOT_API_RATE_LIMIT_EXCLUDE_PATH_PATTERNS=

# GitHub API
# Auth mode: auto uses GitHub App when configured, otherwise PAT.
CODEPILOT_GITHUB_AUTH_MODE=auto
CODEPILOT_GITHUB_TOKEN=
CODEPILOT_GITHUB_APP_ID=
CODEPILOT_GITHUB_APP_PRIVATE_KEY=
CODEPILOT_GITHUB_APP_PRIVATE_KEY_BASE64=
CODEPILOT_GITHUB_APP_INSTALLATION_ID=
CODEPILOT_GITHUB_APP_TOKEN_CACHE_SKEW_SECONDS=60
CODEPILOT_GITHUB_COMMENT_ENABLED=false
CODEPILOT_GITHUB_COMMENT_MARKER=<!-- codepilot-ai-review:liche719/codeAireview -->
CODEPILOT_GITHUB_INLINE_COMMENT_ENABLED=false
CODEPILOT_GITHUB_INLINE_COMMENT_MAX_PER_TASK=10
CODEPILOT_GITHUB_BOT_MENTION_ALIASES=@x-pilotx,@X-PilotX
CODEPILOT_GITHUB_ALLOWED_REPOSITORIES=
CODEPILOT_GITHUB_ALLOWED_COMMENT_AUTHOR_ASSOCIATIONS=OWNER,MEMBER,COLLABORATOR
CODEPILOT_GITHUB_FIX_ENABLED=false
CODEPILOT_GITHUB_FIX_MAX_FILES=3
CODEPILOT_GITHUB_FIX_MAX_CHANGED_LINES=120
CODEPILOT_GITHUB_FIX_VALIDATION_COMMAND=git diff --check
CODEPILOT_GITHUB_FIX_ALLOWED_VALIDATION_COMMANDS=git diff --check
CODEPILOT_GITHUB_FIX_VALIDATION_INHERIT_ENVIRONMENT=false
CODEPILOT_GITHUB_FIX_VALIDATION_TIMEOUT_SECONDS=300

# GitHub Webhook
CODEPILOT_GITHUB_WEBHOOK_ENABLED=false
CODEPILOT_GITHUB_WEBHOOK_SECRET=
CODEPILOT_GITHUB_WEBHOOK_SKIP_SIGNATURE_WHEN_SECRET_EMPTY=false

# LLM
CODEPILOT_LLM_API_KEY=
CODEPILOT_LLM_BASE_URL=https://api.openai.com/v1
CODEPILOT_LLM_MODEL=gpt-4o-mini
CODEPILOT_LLM_REVIEW_STRUCTURED_OUTPUT_ENABLED=true
CODEPILOT_LLM_CALL_LOG_CLEANUP_ENABLED=true
CODEPILOT_LLM_CALL_LOG_RETENTION_DAYS=30
CODEPILOT_LLM_CALL_LOG_CLEANUP_CRON=0 30 */6 * * *

# Embedding
CODEPILOT_EMBEDDING_API_KEY=
CODEPILOT_EMBEDDING_BASE_URL=https://api.openai.com/v1
CODEPILOT_EMBEDDING_MODEL=text-embedding-3-small

# Review Limits
CODEPILOT_REVIEW_MAX_FILES_PER_TASK=30
CODEPILOT_REVIEW_MAX_PATCH_CHARS_PER_FILE=12000
CODEPILOT_REVIEW_MAX_TOTAL_PATCH_CHARS=80000

# PostgreSQL
CODEPILOT_DB_NAME=codepilot
CODEPILOT_DB_URL=jdbc:postgresql://localhost:15432/codepilot
CODEPILOT_DB_USERNAME=codepilot
CODEPILOT_DB_PASSWORD=codepilot123

# Redis
CODEPILOT_REDIS_HOST=localhost
CODEPILOT_REDIS_PORT=16379
CODEPILOT_REDIS_DATABASE=0
CODEPILOT_REDIS_TIMEOUT=3s

# RabbitMQ
CODEPILOT_RABBITMQ_HOST=localhost
CODEPILOT_RABBITMQ_PORT=5672
CODEPILOT_RABBITMQ_USERNAME=codepilot
CODEPILOT_RABBITMQ_PASSWORD=codepilot123
CODEPILOT_RABBITMQ_VIRTUAL_HOST=/
CODEPILOT_RABBITMQ_DEFAULT_REQUEUE_REJECTED=false
